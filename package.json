{
  "name": "mcp-server-wework",
  "version": "0.1.0",
  "description": "An MCP server for WeWork bookings and space search, published as a Node package backed by GopherJS.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "mcp-server-wework": "bin/wework-mcp.js",
    "wework-mcp": "bin/wework-mcp.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "mise run build_js",
    "build:native": "mise run build_native",
    "test": "mise run test",
    "prepack": "mise run build_js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wework",
    "stdio"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
